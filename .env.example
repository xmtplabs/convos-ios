# Convos Local Development Environment Configuration
# Copy this file to .env and fill in your Firebase App Check debug token.
# `Scripts/setup.sh` does this for you automatically.

# Firebase App Check Debug Token
#
# A stable UUID so Firebase App Check accepts requests from your simulator
# without re-registering after every rebuild.
#
# Setup:
#   1. Generate a UUID (setup.sh does this for you): uuidgen
#   2. Register it at https://console.firebase.google.com/u/1/project/convos-otr/appcheck/apps
#      → iOS app for your scheme (Dev: org.convos.ios-preview,
#        Local: org.convos.ios-local, Prod: org.convos.ios)
#      → overflow menu (⋮) → Manage debug tokens → Add debug token
#   3. Only used for Local/Dev — production builds ignore it.
FIREBASE_APP_CHECK_DEBUG_TOKEN=

# Agent attestation override (DEBUG builds only)
#
# Lets locally-run CLI agents (e.g. `convos agent serve --attestation ...`)
# verify against a self-minted Ed25519 keypair instead of the deployed
# `.well-known/agents.json`. Paste the `jwks` block from
#   convos attestation generate <inboxId>
# as a single-line value. Wrap in single quotes so the inner double quotes
# survive shell parsing. Leave empty in production-shaped environments.
#
# AGENT_DEBUG_JWKS='{"keys":[{"kid":"convos-agents-test","kty":"OKP","crv":"Ed25519","x":"...","use":"sig","issuer":"convos"}]}'
AGENT_DEBUG_JWKS=

# ----------------------------------------------------------------------
# Fastlane: firebase_pr lane (ad-hoc PR builds → Firebase App Distribution)
# ----------------------------------------------------------------------
# Required when running `bundle exec fastlane firebase_pr` locally. In CI
# these come from GitHub Actions secrets/vars (see .github/workflows/firebase-pr.yml).

# Firebase iOS app id for the PR Preview bundle (org.convos.ios-preview.pr).
# Find it in the Firebase console → Project settings → Your apps.
# Format: 1:NNN:ios:HEX
FIREBASE_APP_ID_PR=

# Local fastlane invocation: absolute path to a Firebase service account
# JSON with the "Firebase App Distribution Admin" role.
# (CI passes the JSON content directly via FIREBASE_SERVICE_ACCOUNT_JSON_CONTENT
# so nothing touches disk on the runner.)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Comma-separated tester group aliases configured in the Firebase console.
# Defaults to "internal-testers" when unset.
FIREBASE_TESTER_GROUPS=internal-testers

# Passphrase used to encrypt the convos-certificates fastlane match repo.
MATCH_PASSWORD=

