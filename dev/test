#!/bin/bash
set -eou pipefail

# Usage: dev/test [--unit] [--verbose]
#   --unit     Run only unit tests (no Docker required)
#   --verbose  Show full output including app logs
#   (none)     Run all tests with local XMTP node (requires Docker)

VERBOSE=false
UNIT_TESTS=false

for arg in "$@"; do
    case $arg in
        --unit)
            UNIT_TESTS=true
            ;;
        --verbose|-v)
            VERBOSE=true
            ;;
        --help|-h)
            echo "Usage: dev/test [--unit] [--verbose]"
            echo "  --unit     Run only unit tests (no Docker required)"
            echo "  --verbose  Show full output including app logs"
            echo "  (none)     Run all tests with local XMTP node (requires Docker)"
            exit 0
            ;;
        *)
            echo "Unknown option: $arg"
            echo "Use --help for usage information"
            exit 1
            ;;
    esac
done

# Function to filter test output for cleaner display
filter_test_output() {
    if [ "$VERBOSE" = true ]; then
        # Filter out xmtp_mls/xmtpv3 Rust library logs even in verbose mode
        grep -v -E "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*(xmtp|INFO|WARN|ERROR)" || true
    else
        # Show only: build status, test results (passed/failed), issues, and final summary
        # Use grep -v first to exclude xmtp logs, then grep for wanted patterns
        grep -v -E "^[0-9]{4}-[0-9]{2}-[0-9]{2}T" | \
        grep -E "(^Building|^Build complete|Test Suite.*passed|Test Suite.*failed|passed after|failed after|recorded an issue|with [0-9]+ issue|Test run with|^error:|^􁁛|^􀢄)" || true
    fi
}

# Check for --unit flag to run only unit tests without Docker
if [ "$UNIT_TESTS" = true ]; then
    echo "🧪 Running ConvosCore unit tests (no Docker required)..."
    echo ""

    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    cd "$SCRIPT_DIR/../ConvosCore"

    # Run only unit tests that don't require network
    swift test --filter "Base64URL|DataHex|Compression|Custom Metadata" 2>&1 | filter_test_output
    exit ${PIPESTATUS[0]}
fi

echo "🧪 Running ConvosCore integration tests with local XMTP node..."
echo ""

# Check if Docker is running
if ! docker info > /dev/null 2>&1; then
    echo "❌ Docker is not running. Please start Docker and try again."
    exit 1
fi

# Start the XMTP node
echo "🐳 Starting local XMTP node..."
"$(dirname "$0")/up"

# Wait for the node to be ready
echo "⏳ Waiting for XMTP node to be ready..."
max_attempts=30
attempt=0

while [ $attempt -lt $max_attempts ]; do
    if nc -z localhost 5556 2>/dev/null; then
        echo "✅ XMTP node is ready!"
        sleep 3  # Give it a few more seconds to fully initialize
        break
    fi

    attempt=$((attempt + 1))
    echo "Attempt $attempt/$max_attempts - waiting for XMTP node..."
    sleep 2
done

if [ $attempt -ge $max_attempts ]; then
    echo "❌ XMTP node failed to start within the timeout"
    "$(dirname "$0")/compose" logs
    exit 1
fi

# Run the tests
echo ""
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR/../ConvosCore"

# Run tests using swift test (works on macOS without simulator)
set +e  # temporarily disable exit on error to capture the exit code

# Build first to avoid "multiple producers" error when running tests in parallel
# This ensures compilation happens in a single process before parallel test execution
echo "📦 Building tests..."
swift build --build-tests -q 2>&1 | filter_test_output
build_exit_code=${PIPESTATUS[0]}

if [ $build_exit_code -ne 0 ]; then
    echo "❌ Build failed!"
    exit $build_exit_code
fi

# Run tests with a timeout because XMTP background workers may prevent clean exit
# Tests complete but the process can hang due to background worker cleanup issues
echo "🏃 Running tests..."

# Start tests in background, writing to log file
TEST_SERVER_ENABLED=true swift test --no-parallel --skip-build > test-output.log 2>&1 &
TEST_PID=$!

# Monitor progress and enforce timeout
TIMEOUT=180
ELAPSED=0
while kill -0 $TEST_PID 2>/dev/null; do
    sleep 5
    ELAPSED=$((ELAPSED + 5))

    # Show progress with current test name
    PASSED=$(grep -c "passed after" test-output.log 2>/dev/null || echo "0")
    FAILED=$(grep -c "failed after.*issue" test-output.log 2>/dev/null || echo "0")
    CURRENT_TEST=$(grep "Test \".*\" started" test-output.log 2>/dev/null | tail -1 | sed 's/.*Test "\([^"]*\)".*/\1/' || echo "")
    if [ -n "$CURRENT_TEST" ]; then
        echo "  ⏳ Running: $CURRENT_TEST ($PASSED passed, $FAILED failed, ${ELAPSED}s)"
    else
        echo "  ⏳ Running... ($PASSED passed, $FAILED failed, ${ELAPSED}s)"
    fi

    if [ $ELAPSED -ge $TIMEOUT ]; then
        echo ""
        echo "⏱️  Test process didn't exit after ${TIMEOUT}s, forcing termination..."
        echo "  (This is usually due to XMTP background workers not shutting down cleanly)"
        kill $TEST_PID 2>/dev/null
        sleep 2
        kill -9 $TEST_PID 2>/dev/null
        break
    fi
done

wait $TEST_PID 2>/dev/null

# Show filtered results
echo ""
filter_test_output < test-output.log

# Determine test result from log file
if grep -q "Test run with.*passed after" test-output.log 2>/dev/null; then
    test_exit_code=0
elif grep -q "failed after.*with.*issue" test-output.log 2>/dev/null; then
    test_exit_code=1
else
    # Check if all suites completed even without final summary
    SUITES_STARTED=$(grep -c "Suite.*started" test-output.log 2>/dev/null || echo "0")
    SUITES_COMPLETED=$(grep -c "Suite.*after.*seconds" test-output.log 2>/dev/null || echo "0")
    if [ "$SUITES_STARTED" = "$SUITES_COMPLETED" ] && [ "$SUITES_STARTED" != "0" ]; then
        test_exit_code=0
    else
        test_exit_code=1
    fi
fi
set -e  # re-enable exit on error

if [ $test_exit_code -eq 0 ]; then
    echo ""
    echo "✅ All tests passed!"
else
    echo ""
    echo "❌ Tests failed!"
    echo ""
    echo "📝 Full output saved to: ConvosCore/test-output.log"
    echo "💡 Run with --verbose to see full output"
fi

# Stop the XMTP node
echo ""
echo "🛑 Stopping Docker containers..."
cd "$SCRIPT_DIR"
./compose down

exit $test_exit_code
